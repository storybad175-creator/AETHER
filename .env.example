# ── Garena guest credentials ──────────────────────────────────────
# Obtain by following the guest JWT extraction guide in README.md
GARENA_GUEST_UID=your_guest_uid_here
GARENA_GUEST_TOKEN=your_guest_token_here

# ── AES crypto constants ──────────────────────────────────────────
# Community-extracted from Free Fire APK binary analysis
# See README.md for extraction methodology and how to update
AES_KEY=your_32_byte_hex_key_here
AES_IV=your_16_byte_hex_iv_here

# ── Cache settings ────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=500

# ── API settings ──────────────────────────────────────────────────
OB_VERSION=OB53
SERVER_PORT=8080
LOG_LEVEL=INFO

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_RPM=30
