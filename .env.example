# ── Garena guest credentials ──────────────────────────────────────
# Obtain by following the guest JWT extraction guide in README.md
# Captured from https://loginbp.ggblueshark.com/MajorLogin
GARENA_GUEST_UID=your_guest_uid_here
GARENA_GUEST_TOKEN=your_guest_token_here

# ── AES crypto constants ──────────────────────────────────────────
# Community-extracted from Free Fire APK binary analysis (libil2cpp.so)
# Format: 64-char Hex string for Key (32 bytes), 32-char Hex for IV (16 bytes)
AES_KEY=your_32_byte_hex_key_here
AES_IV=your_16_byte_hex_iv_here

# ── Cache settings ────────────────────────────────────────────────
# Player data is cached for 5 minutes by default
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=500

# ── API settings ──────────────────────────────────────────────────
# Current game version (Update this for OB54, etc.)
OB_VERSION=OB53
SERVER_PORT=8080
LOG_LEVEL=INFO

# ── Rate limiting ─────────────────────────────────────────────────
# Maximum requests per minute per client IP
RATE_LIMIT_RPM=30
